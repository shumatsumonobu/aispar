# --- 認証（どちらか一方を設定） ---

# 方法1: Gemini APIキー（手軽）
# https://aistudio.google.com/apikey で取得
# GEMINI_API_KEY=your-gemini-api-key

# 方法2: サービスアカウント（Vertex AI経由）
# https://console.cloud.google.com/iam-admin/serviceaccounts で作成
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=your-project-id

# Google Custom Search API キー
# https://console.cloud.google.com/apis/credentials で作成
GOOGLE_CSE_API_KEY=your-cse-api-key

# Custom Search Engine ID
# https://programmablesearchengine.google.com/ で作成
GOOGLE_CSE_ID=your-cse-id

# サーバーポート（省略時: 3000）
# PORT=3000
